# Example SOPS AGE key for Flux
# 1. Generate AGE keypair: age-keygen -o age.key
# 2. Copy public key to this file
# 3. Encrypt with SOPS: sops -e -i sops-age.sops.yaml
# 4. Never commit the unencrypted version!

apiVersion: v1
kind: Secret
metadata:
  name: sops-age
  namespace: flux-system
stringData:
  age.agekey: |
    # created: <timestamp>
    # public key: age1<your-public-key>
    AGE-SECRET-KEY-1<your-secret-key>
